    "def validate_ip(ip):\n",
    "    parts = ip.split(\".\")\n",
    "    if len(parts) == 4:\n",
    "        return True\n",
    "    else:\n",
    "        return False"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
