def rail_fence_encrypt(text, rails):
    # Edge case
    if rails == 1:
        return text

    # Create empty rows
    fence = ['' for _ in range(rails)]

    current_row = 0
    direction_down = True

    for char in text:
        fence[current_row] += char

        # Change direction at top or bottom
        if current_row == 0:
            direction_down = True
        elif current_row == rails - 1:
            direction_down = False

        # Move row
        if direction_down:
            current_row += 1
        else:
            current_row -= 1

    # Join all rows
    return ''.join(fence)


# Example
text = input("Enter a message to encrypt")
rails = int(input("Enter number of rails"))

encrypted = rail_fence_encrypt(text, rails)
print("Encrypted Text:", encrypted)